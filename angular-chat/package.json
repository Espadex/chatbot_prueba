{
  "name": "angular-chat",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "config-env": "node set-env.js",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "npm run config-env && ng serve",
    "start:backend": "dotnet watch run --project ../ChatbotAPI/ChatbotAPI.csproj",
    "build": "npm run config-env && ng build",
    "watch": "npm run config-env && ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.0",
    "@types/highlight.js": "^9.12.4",
    "@types/jasmine": "~5.1.0",
    "@types/marked": "^5.0.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.5.2"
  }
}